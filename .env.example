# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=hospital_adt_events
KAFKA_ALERTS_TOPIC=hospital_alerts
KAFKA_CONSUMER_GROUP=hospital_pipeline

# Spark
SPARK_MASTER=local[*]
SPARK_CHECKPOINT_DIR=./data/checkpoints

# Storage
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold
SQLITE_DB_PATH=./data/hospital.db

# Airflow
AIRFLOW_HOME=./airflow

# LLM (Anthropic Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API
API_HOST=0.0.0.0
API_PORT=8000

# Simulator
SIMULATOR_SPEED_MULTIPLIER=1.0
SIMULATOR_SPIKE_PROBABILITY=0.1
SIMULATOR_EVENTS_PER_SECOND=5

# Azure (Phase 7 - fill when ready)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_SQL_CONNECTION_STRING=
